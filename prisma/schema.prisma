generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Portfolio history ────────────────────────────────────────────────────────

model Draft {
  id           String   @id
  contestName  String
  entryFee     Float
  draftedAt    DateTime
  startingPick Int
  totalTeams   Int
  source       String   @default("csv") // "csv" | "json" | "live"
  players      Player[]

  @@map("drafts")
}

model Player {
  id           String  @id @default(cuid())
  name         String
  rawName      String?
  team         String
  position     String
  draftedPick  Int
  draftedRound Int
  adpAtDraft   Float?
  currentAdp   Float?
  draftId      String
  draft        Draft   @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@map("players")
  @@index([name])
}

model RawImport {
  id         String   @id @default(cuid())
  filename   String
  importedAt DateTime @default(now())
  rowCount   Int
  rawData    String
  importType String   @default("dk_draft")

  @@map("raw_imports")
}

// ─── Canonical player universe ────────────────────────────────────────────────
// Single source of truth for every player. All analytics, the live assistant,
// and ADP lookups read from this table. Updated by two routes:
//   POST /api/import/master-rankings  — bulk upsert from FantasyPros CSV
//   POST /api/import/dk-adp           — updates dkAdp only (preserves udAdp/delta)
//   POST /api/import/team-totals      — writes Vegas data (joined by team)
//
// To manually update ADP:
//   dkAdp      → re-import DK_ADP_Export.csv via the dashboard "DK ADP" dropzone
//   udAdp      → re-import the FantasyPros multi-site CSV (updates both UD and FP rank)
//   adpDelta   → auto-recomputed as (dkAdp - udAdp) whenever either is updated

model PlayerUniverse {
  id       String @id @default(cuid())
  name     String @unique   // canonical full name — the join key everywhere
  team     String           // normalized 2-3 letter code, e.g. "DAL"
  position String           // "QB" | "RB" | "WR" | "TE" | "K" | "DST"
  bye      Int?             // bye week number

  // ── ADP (update via CSV import, see routes above) ─────────────────────────
  dkAdp    Float?           // DraftKings ADP — primary sort key for live assistant
  udAdp    Float?           // Underdog ADP
  adpDelta Float?           // dkAdp - udAdp (positive = later on DK = DK value)
  fpRank   Int?             // FantasyPros consensus rank
  avgAdp   Float?           // multi-site average ADP

  // ── Vegas / playoff projections (keyed by team via TeamWeekProjection) ────
  // Denormalized here at write-time so the live assistant can read one table.
  week15Opp        String?
  week15TeamTotal  Float?
  week15OU         Float?
  week16Opp        String?
  week16TeamTotal  Float?
  week16OU         Float?
  week17Opp        String?  // used for W17 bring-back detection
  week17TeamTotal  Float?
  week17OU         Float?
  week18Opp        String?
  week18TeamTotal  Float?
  week18OU         Float?
  playoffTotalOU   Float?   // avg of wk15-17 game O/Us
  impliedTeamTotal Float?   // avg of wk15-17 team totals

  updatedAt DateTime @updatedAt

  @@index([team])
  @@map("player_universe")
}

// ─── Team Vegas data (write source — denormalized into PlayerUniverse on import) ─
// Kept as the authoritative Vegas record. PlayerUniverse gets its Vegas fields
// populated from here whenever team-totals CSV is imported.

model TeamWeekProjection {
  id                    String   @id @default(cuid())
  team                  String   @unique
  week15Opp             String?
  week15TeamTotal       Float?
  week15OU              Float?
  week16Opp             String?
  week16TeamTotal       Float?
  week16OU              Float?
  week17Opp             String?
  week17TeamTotal       Float?
  week17OU              Float?
  projectedPlayoffTotal Float?
  week18Opp             String?
  week18TeamTotal       Float?
  week18OU              Float?
  updatedAt             DateTime @updatedAt

  @@map("team_week_projections")
}

// ─── Beersheets positional value (feature-flagged) ────────────────────────────

model PositionalValue {
  id         String   @id @default(cuid())
  playerName String
  position   String
  value      Float
  updatedAt  DateTime @updatedAt

  @@unique([playerName, position])
  @@map("positional_values")
}
